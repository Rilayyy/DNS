#!/usr/bin/env python3

import argparse, socket, time, json, select, struct, sys, math
from dnslib import DNSRecord, DNSHeader, RR, QTYPE, A
from cache import DNSCache
from collections import defaultdict

class Server:
    def __init__(self, root_ip, domain, port):
        self.root_ip = root_ip
        self.domain = ""

        self.socket = socket.socket(socket.AF_INET, socket.SOCK_DGRAM)
        self.socket.bind(("127.0.0.1", port))
        self.port = self.socket.getsockname()[1]

        self.authoritative_records = defaultdict(list)
        self.cache = DNSCache()
        self._parse_zone_file(domain)

        print(f"Bound to port {self.port}")
        sys.stdout.flush()

    def _parse_zone_file(self, zone_file):
        """
        Reads the zone file, extracts the SOA records to establish domain space and maps all records to a dic

        :param zone_file: File path to the zone file
        :return: None
        """

        with open(zone_file, 'r') as f:
            zone_data = f.read()

        raw_record = RR.fromZone(zone_data)

        for record in raw_record:
            if record.rtype == QTYPE.SOA:
                self.domain = str(record.rname)

            domain = str(record.rname)
            qtype = record.rtype

            self.authoritative_records[(domain, qtype)].append(record)

    def log(self, message):
        sys.stderr.write(message + "\n")
        sys.stderr.flush()

    def send(self, addr, message):
        self.log("Sending message:\n%s" % message)
        self.socket.sendto(message.pack(), addr)

    def recv(self, socket):
        data, addr = socket.recvfrom(65535)

        # Unpack the DNS request
        request = DNSRecord.parse(data)
        self.log("Received message:\n%s" % request)

        qname = str(request.q.qname)
        qtype = request.q.qtype

        # YOU WILL NEED TO ACTUALLY DO SOMETHING SMART HERE
        # WE ARE JUST REPLYING WITH A FIXED RESPONSE
        response = request.reply()

        if qname.endswith(self.domain):
            response.header.aa = 1

            correct_records = self.authoritative_records.get((qname, qtype), [])

            if correct_records:
                for record in correct_records:
                    response.add_answer(record)
            else:
                """Check for CNAME record and follow the chain"""
                cname_records = self.authoritative_records.get((qname, QTYPE.CNAME), [])

                if cname_records:
                    """Add the CNAME record to the answer"""
                    for cname_record in cname_records:
                        response.add_answer(cname_record)

                    """Follow the CNAME chain to get the target record"""
                    target_name = str(cname_records[0].rdata).lower()

                    """Get the target record (A, AAAA, etc.) from the CNAME target"""
                    target_records = self.authoritative_records.get((target_name, qtype), [])
                    if target_records:
                        for target_record in target_records:
                            response.add_answer(target_record)
                    else:
                        """Target doesn't have requested type - check if it has another CNAME"""
                        next_cname = self.authoritative_records.get((target_name, QTYPE.CNAME), [])
                        if next_cname:
                            for cname_record in next_cname:
                                response.add_answer(cname_record)
                            next_target = str(next_cname[0].rdata).lower()
                            final_records = self.authoritative_records.get((next_target, qtype), [])
                            if final_records:
                                for final_record in final_records:
                                    response.add_answer(final_record)
                else:
                    response.header.rcode = 3

            self.send(addr, response)
        
        else:
            external_response = self._resolve_external(request)
        
            if external_response:
                self.send(addr, external_response)
            else:
                response.header.rcode = 2
                self.send(addr, response)
        

    def _resolve_external(self, request):
        """
        Recursively resolves a DNS query by walking the DNS hierarchy.

        Starts at the root server and follows NS referrals hop-by-hop
        until an authoritative answer is found. Uses cache at each step.

        :param request: The DNS request to resolve
        :return: DNSRecord with the final answer, or None if resolution fails
        """
        qname = str(request.q.qname).lower().rstrip('.')
        qtype = request.q.qtype

        """Check cache first before querying upstream"""
        cached_records = self.cache.get(qname, qtype)
        if cached_records:
            response = request.reply()
            for record in cached_records:
                response.add_answer(record)
            return response

        """Start recursive resolution from root"""
        current_server = self.root_ip
        max_iterations = 10
        visited_servers = set()

        for iteration in range(max_iterations):
            if current_server in visited_servers:
                """Loop detected, bail out"""
                return None
            visited_servers.add(current_server)

            """Query the current server"""
            response = self._query_server(request, current_server)
            if not response:
                return None

            """Cache the response before processing"""
            self.cache.cache_response(response)

            """If we have an answer, return it"""
            if response.rr:
                return response

            """Look for NS referral in authority section"""
            ns_record = None
            ns_ip = None

            for auth in response.auth:
                if auth.rtype == QTYPE.NS:
                    ns_name = str(auth.rdata).lower().rstrip('.')
                    ns_record = auth

                    """Look for A record in additional section"""
                    for ar in response.ar:
                        if str(ar.rname).lower().rstrip('.') == ns_name and ar.rtype == QTYPE.A:
                            ns_ip = str(ar.rdata)
                            break
                    break

            if not ns_record:
                """No referral found, resolution failed"""
                return response

            if not ns_ip:
                """Need to resolve NS name to IP - try cache first"""
                ns_cached = self.cache.get(ns_name, QTYPE.A)
                if ns_cached:
                    ns_ip = str(ns_cached[0].rdata)
                else:
                    """Can't get IP for NS server, resolution failed"""
                    return None

            current_server = ns_ip

        """Too many iterations, bail out"""
        return None

    def _query_server(self, request, server_ip):
        """
        Send a DNS query to a specific server and return the response.

        :param request: The DNS request to send
        :param server_ip: The IP address of the server to query
        :return: DNSRecord response, or None on error
        """
        proxy_socket = socket.socket(socket.AF_INET, socket.SOCK_DGRAM)
        proxy_socket.settimeout(5.0)

        try:
            proxy_socket.sendto(request.pack(), (server_ip, 60053))
            response_data, _ = proxy_socket.recvfrom(65535)
            return DNSRecord.parse(response_data)
        except Exception as e:
            self.log(f"query to {server_ip} failed: {e}")
            return None
        finally:
            proxy_socket.close()
    

    def run(self):
        seq = 0
        while True:
            socks = select.select([self.socket], [], [], 0.1)[0]
            for conn in socks:
                self.recv(conn)

        return

if __name__ == "__main__":
    parser = argparse.ArgumentParser(description='send data')
    parser.add_argument('root_ip', type=str, help="The IP address of the root server")
    parser.add_argument('zone', type=str, help="The zone file for this server")
    parser.add_argument('--port', type=int, help="The port this server should bind to", default=0)
    args = parser.parse_args()
    sender = Server(args.root_ip, args.zone, args.port)
    sender.run()